rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if caller has a valid profile
    function hasProfile() {
      return request.auth != null
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    // Helper: get the caller's role from usuarios collection
    // Safe: only called after hasProfile() confirms doc exists
    function getUserRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    function isSuperAdmin() {
      return hasProfile() && getUserRole() == 'super_admin';
    }

    function isEditorOrAbove() {
      return hasProfile() && getUserRole() in ['super_admin', 'editor'];
    }

    function isAuthenticated() {
      return hasProfile();
    }

    // ========== §61.R6 RBAC dinámico — hasPermission() ==========
    // Helper canónico server-side equivalente a AP.hasPermission(permId)
    // del frontend. Lee usuarios/{uid}.permissions[] denormalizado.
    //
    // Wildcard '*': si el array contiene '*', se permite cualquier
    // permission (aplica a system_super_admin y custom roles que el
    // super_admin haya marcado como wildcard).
    //
    // Defensive: si el doc no tiene 'permissions' o es null (user
    // pre-migración R4), retorna false. Las callsites combinan
    // hasPermission() con OR a los helpers legacy isSuperAdmin() /
    // isEditorOrAbove() para preservar compatibilidad durante la
    // transición. R8 cleanup eliminará los OR legacy cuando todos
    // los users estén migrados.
    function getUserPermissions() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.permissions;
    }

    function hasPermissionsField() {
      return hasProfile()
        && 'permissions' in get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data
        && getUserPermissions() != null
        && getUserPermissions() is list;
    }

    function hasPermission(perm) {
      return hasPermissionsField()
        && (perm in getUserPermissions() || '*' in getUserPermissions());
    }

    // F4.5: Optimistic locking — validate _version increment
    // Allows: new docs with _version=1, updates with _version+1, or migration from null→1
    function validVersion() {
      return request.resource.data._version == resource.data._version + 1
          || (resource.data._version == null && request.resource.data._version == 1);
    }

    function validCreateVersion() {
      return request.resource.data._version == 1;
    }

    // F4.3: Size limits — Firestore enforces 1MB natively.
    // This helper is kept for documentation but removed from rules
    // to avoid false denials with request.resource.size edge cases.
    // function isReasonableSize() {
    //   return request.resource.size < 1048576;
    // }

    // ========== VEHICULOS ==========
    match /vehiculos/{vehiculoId} {
      // Public catalog — anyone can browse the inventory
      allow read: if true;

      // §61.R6 — hasPermission('vehicles.create') con fallback legacy.
      // Super Admin bypasses version check; Editor+ must set _version=1.
      allow create: if isSuperAdmin()
        || (isEditorOrAbove() && validCreateVersion())
        || (hasPermission('vehicles.create') && validCreateVersion());

      // §61.R6 — hasPermission('vehicles.edit') con fallback legacy.
      allow update: if isSuperAdmin()
        || (isEditorOrAbove() && validVersion())
        || (hasPermission('vehicles.edit') && validVersion());

      // §61.R6 — hasPermission('vehicles.delete') con fallback legacy.
      allow delete: if isSuperAdmin()
        || hasPermission('vehicles.delete');

      // ========== VEHICLE AUDIT LOG (subcollection) ==========
      match /auditLog/{logId} {
        allow read: if isAuthenticated();
        // §61.R6 — auditLog es write-on-edit; usa permission 'vehicles.edit'.
        allow create: if isEditorOrAbove()
          || hasPermission('vehicles.edit')
          || hasPermission('vehicles.create');
        allow delete: if isSuperAdmin()
          || hasPermission('vehicles.delete');
      }
    }

    // ========== CONCESIONARIOS ==========
    // §61.R6 — granularidad: dealers.read/create/edit/delete.
    match /concesionarios/{concesionarioId} {
      allow read: if isAuthenticated()
        || hasPermission('dealers.read');
      allow create: if isSuperAdmin()
        || hasPermission('dealers.create');
      allow update: if isSuperAdmin()
        || hasPermission('dealers.edit');
      allow delete: if isSuperAdmin()
        || hasPermission('dealers.delete');
    }

    // ========== MARCAS ==========
    // §61.R6 — granularidad: brands.create/edit/delete.
    match /marcas/{marcaId} {
      allow read: if true;

      allow create: if isSuperAdmin()
        || isEditorOrAbove()
        || hasPermission('brands.create');
      allow update: if isSuperAdmin()
        || (isEditorOrAbove() && validVersion())
        || (hasPermission('brands.edit') && validVersion());

      allow delete: if isSuperAdmin()
        || hasPermission('brands.delete');
    }

    // ========== USUARIOS ==========
    // §61.R6 — granularidad: users.read/create/edit/delete.
    // Importante: 'users.edit/create/delete' debe ser asignable solo
    // a roles de gestión (system_super_admin tiene '*'). Custom roles
    // que no incluyan estos permissions NO podrán gestionar usuarios.
    match /usuarios/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId
        || isSuperAdmin()
        || hasPermission('users.read')
      );

      // Super admin (o role custom con users.create / users.delete)
      // gestiona todo el doc del usuario (alta, baja, rol, bloqueado, etc.)
      allow create: if isSuperAdmin()
        || hasPermission('users.create');
      allow delete: if isSuperAdmin()
        || hasPermission('users.delete');

      // §23 FASE 7 + §43 ADR-043 — Self-service diff-keys.
      // El propio usuario (super_admin/editor/viewer) puede actualizar SOLO
      // un set whitelisted de campos de SU propio doc:
      //
      //   Trusted devices + 2FA (§23 FASE 7):
      //     - trustedDevices (array de dispositivos)
      //     - habilitado2FA (toggle propio)
      //     - telefono2FA, prefijo2FA
      //     - ultimoAcceso, lastLoginAt
      //     - fcmTokens (Sprint 8)
      //
      //   Perfil personal (§43 — sec-profile):
      //     - nombre, telefono, prefijo, cargo
      //     - photoURL (avatar Firebase Storage)
      //     - tipoDoc (CC/CE/Pasaporte — editable)
      //     - cedula (one-time-edit ENFORCED por la sub-condición abajo)
      //     - cedulaChangeRequested, cedulaChangeRequestedAt (flag de solicitud)
      //
      //   Telegram bot link (§39/§40):
      //     - telegramChatId, telegramLinkedAt, telegramUserName, telegramLastUsedAt
      //
      // GARANTÍAS DE SEGURIDAD (campos PROHIBIDOS para self-update):
      //   - rol: editor/viewer NO pueden escalar a super_admin
      //   - email: cambios sensibles solo super_admin
      //   - bloqueado: editor NO puede auto-desbloquearse
      //   - estado: idem
      //   - creadoEn / creadoPor: inmutables tras la creación
      //
      // CÉDULA ONE-TIME-EDIT (§43): la cédula es identidad legal del usuario.
      // Una vez seteada, NO se puede cambiar libremente. Patrón cliente:
      // admin-profile.js bloquea el campo con un candado tras el primer save.
      // Patrón server: la sub-condición de abajo permite escribir 'cedula'
      // SOLO si el valor anterior estaba vacío. Para cambios posteriores
      // el usuario debe solicitar al super_admin via cedulaChangeRequested.
      //
      // Patrón: diff().affectedKeys().hasOnly([whitelist]) garantiza
      // que la lista de campos modificados es subconjunto del array.
      //
      // §61.R6 — admin con users.edit (o users.create implícito) puede
      // editar otros usuarios (rol, bloqueado, etc). Self-update con
      // whitelist diff-keys sigue funcionando para cualquier user
      // autenticado (independiente de su role).
      // §212 ANTI-TAKEOVER: la gestión por admin (super_admin / users.edit) NUNCA
      // aplica al doc del DUEÑO (roleId 'system_super_admin' o permissions con '*')
      // — solo el propio dueño lo edita vía self-update. Antes NO estaba enforced
      // (hueco FATAL del pase adversarial ④ RBAC): cualquier users.edit podía
      // degradar/vaciar/bloquear al CEO. El check es sobre resource.data (doc EXISTENTE)
      // → anti-spoof (no se puede burlar cambiando roleId en la misma escritura).
      allow update: if
        ( (isSuperAdmin() || hasPermission('users.edit'))
          && !(resource.data.get('roleId', '') == 'system_super_admin'
               || ('*' in resource.data.get('permissions', []))) )
        || (request.auth.uid == userId &&
            request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly([
                    // Trusted devices + 2FA (§23)
                    'trustedDevices', 'ultimoAcceso', 'lastLoginAt',
                    'habilitado2FA', 'telefono2FA', 'prefijo2FA', 'fcmTokens',
                    // Perfil personal (§43)
                    'nombre', 'telefono', 'prefijo', 'cargo', 'photoURL',
                    'tipoDoc', 'cedula',
                    'cedulaChangeRequested', 'cedulaChangeRequestedAt',
                    // Telegram bot link (§39/§40)
                    'telegramChatId', 'telegramLinkedAt',
                    'telegramUserName', 'telegramLastUsedAt',
                    // §48 — Recovery system: backup codes + security questions
                    // Hashes SHA-256 (no plaintext). User puede generar/regenerar
                    // sus propios códigos y configurar sus preguntas.
                    'backupCodes', 'backupCodesGeneratedAt',
                    'securityQuestions', 'securityQuestionsUpdatedAt'
                ])
            // §43 — Cédula one-time-edit: si se está modificando 'cedula',
            // el valor anterior DEBE estar vacío. Cambios posteriores se
            // bloquean del lado del servidor (defensa-en-profundidad
            // independiente del lock visual del cliente).
            && (
                !request.resource.data.diff(resource.data).affectedKeys().hasAny(['cedula'])
                || resource.data.get('cedula', '') == ''
            ));

      // ========== USER DRAFTS (subcollection) ==========
      match /drafts/{draftId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ========== CLIENTES (public users — anonymous OR registered) ==========
    // Completely separate from `usuarios` (admin panel).
    // A public user (including anonymous Firebase Auth users) can ONLY
    // read/write their own document. They have NO access to admin collections.
    //
    // Anonymous users are auto-signed-in by auth.js so favorites/historial are
    // always tied to a private uid (no localStorage). When they later register,
    // linkWithCredential preserves the uid → data carries over seamlessly.
    match /clientes/{uid} {
      // Self-service: el cliente lee su propio doc.
      // Admin (editor+): necesario para que admin-crm.js liste TODOS
      // los clientes en el CRM 360 con db.collection('clientes').get().
      // §61.R6 — granularidad: crm.read.
      allow read:   if request.auth != null && (
                        request.auth.uid == uid
                        || isEditorOrAbove()
                        || hasPermission('crm.read')
                    );
      // Create only requires uid match — nombre/email may be empty for anon users
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid;
      // Update: el cliente edita su perfil; admin con crm.edit puede agregar
      // notas/tags del CRM desde el panel admin (crmTags, crmNotes).
      // §61.R6 — granularidad: crm.edit.
      allow update: if request.auth != null && (
                        request.auth.uid == uid
                        || isSuperAdmin()
                        || hasPermission('crm.edit')
                    );
      allow delete: if false; // Users cannot self-delete (data retention)

      match /busquedasGuardadas/{searchId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Phase A4 — Smart Notifications cross-device sync
      // The bell's localStorage is per-device. This subcollection is the
      // canonical synced store. Each notification is read by the same uid
      // that produced it (or by other devices logged in as the same uid).
      match /notifications/{nid} {
        allow read, write, delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ========== RESENAS ==========
    // §61.R6 — granularidad: reviews.create/edit/delete.
    match /resenas/{resenaId} {
      allow read: if true;
      allow create: if isEditorOrAbove()
        || hasPermission('reviews.create');
      allow update: if isEditorOrAbove()
        || hasPermission('reviews.edit');
      allow delete: if isSuperAdmin()
        || hasPermission('reviews.delete');
    }

    // ========== BANNERS ==========
    // §61.R6 — granularidad: banners.create/edit/delete.
    match /banners/{bannerId} {
      allow read: if true;

      allow create: if isSuperAdmin()
        || isEditorOrAbove()
        || hasPermission('banners.create');
      allow update: if isSuperAdmin()
        || (isEditorOrAbove() && validVersion())
        || (hasPermission('banners.edit') && validVersion());

      allow delete: if isSuperAdmin()
        || hasPermission('banners.delete');
    }

    // ========== LEADS (CRM canónico — Fase 1) ==========
    // Repurposed: el bloque `leads` legacy (create público) era vestigial
    // (ningún código del proyecto usaba collection('leads'); el público
    // escribe en `solicitudes`). Ahora `leads` es parte del modelo canónico:
    // lo escribe la capa de ingestión vía Admin SDK (bypassa rules); el
    // cliente público NO tiene acceso (no tiene usuarios/{uid}).
    match /leads/{leadId} {
      // F1 (ADR §176 E0): un lead con deal vinculado (convertedTo.dealId) es
      // INMUTABLE en `status` desde el cliente — evita estados imposibles
      // (ej. "perdido" en Bandeja con su deal en "negociación"). Solo el
      // server lo cambia (Admin SDK bypasea rules: trigger F2 / anulación F7).
      function leadStatusUnlocked() {
        return !('convertedTo' in resource.data)
          || resource.data.convertedTo == null
          || !('dealId' in resource.data.convertedTo)
          || resource.data.convertedTo.dealId == null
          || request.resource.data.status == resource.data.status;
      }
      // F35b (ADR §181): whitelist de estados v3 — los valores retirados
      // (calificado/no_calificado/perdido) se RECHAZAN en escritura; un
      // cliente con la SPA vieja recibe denegación, nunca corrompe.
      // 'descartado' exige razón de picklist (inalcanzable ≠ no_califica).
      function leadStatusV3Ok() {
        return request.resource.data.status == resource.data.status
          || (
            request.resource.data.status in ['nuevo', 'contactado', 'convertido', 'descartado']
            && (request.resource.data.status != 'descartado'
                || request.resource.data.discardReason in
                   ['inalcanzable', 'no_califica', 'duplicado', 'ya_compro_en_otra_parte', 'spam_prueba'])
          );
      }
      allow read:   if hasPermission('crm.read'); // SEC-01 §187: estricto (Opción A — Gemini §169); super pasa por '*'
      allow create: if isSuperAdmin() || hasPermission('crm.edit');
      allow update: if (isSuperAdmin() || hasPermission('crm.edit')) && leadStatusUnlocked() && leadStatusV3Ok();
      allow delete: if isSuperAdmin() || hasPermission('crm.delete');
    }

    // ========== LEAD_INTAKE (F36 §178 — lead rápido del asesor) ==========
    // Colección PROPIA (no toca el puente `solicitudes`): el asesor escribe el
    // doc (funciona offline) y el trigger onLeadIntakeCreated lo proyecta al
    // canónico. Owner FORZADO = quien lo registra. Sin update/delete de cliente
    // (la marca _ingestedAt la pone el server vía Admin SDK).
    match /lead_intake/{intakeId} {
      allow read: if hasPermission('crm.read'); // SEC-01 §187: estricto (Opción A — Gemini §169); super pasa por '*'
      allow create: if (isSuperAdmin() || hasPermission('crm.edit') || hasPermission('crm.create'))
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.nombre is string
        && request.resource.data.nombre.size() > 0
        && (
          (request.resource.data.telefono is string && request.resource.data.telefono.size() >= 7)
          || (request.resource.data.email is string && request.resource.data.email.size() >= 5)
        );
      allow update, delete: if false;
    }

    // ========== CONTACTS (CRM canónico — persona unificada — Fase 1) ==========
    match /contacts/{contactId} {
      // F12 §185 — protocolo _version v2 (optimistic locking): toda edición
      // del cliente DEBE venir con _version = actual + 1 (los triggers
      // también incrementan — Admin SDK bypasea rules pero respeta el
      // protocolo). Campos de servidor (supresión/fusión/índice) y un
      // contacto suprimido o en gracia son INTOCABLES desde el cliente.
      function contactVersionOk() {
        return (!('_version' in resource.data) && request.resource.data._version == 1)
          || request.resource.data._version == resource.data._version + 1;
      }
      function contactServerFieldsUntouched() {
        return !request.resource.data.diff(resource.data).affectedKeys().hasAny(
          ['_suppressed', 'suppressionStatus', 'suppressionExecuteAfter',
           '_mergedInto', '_mergedAt', '_mergedBy', 'dedupKeys',
           'createdAt', 'clienteUid'].toSet());
      }
      function contactEditable() {
        return resource.data.get('_suppressed', false) != true
          && resource.data.get('suppressionStatus', '') != 'pendiente_supresion'
          && resource.data.get('_mergedInto', null) == null;
      }
      allow read:   if hasPermission('crm.read'); // SEC-01 §187: estricto (Opción A — Gemini §169); super pasa por '*'
      allow create: if isSuperAdmin() || hasPermission('crm.edit');
      allow update: if (isSuperAdmin() || hasPermission('crm.edit'))
        && contactVersionOk() && contactServerFieldsUntouched() && contactEditable();
      // §185: el cliente JAMÁS borra contacts — un delete directo durante la
      // gracia dejaría el grafo con PII para siempre (el finalizador lo
      // saltaría como "no-existe"). Toda destrucción va por Admin SDK
      // (crmPurgeLead / executeSuppression).
      allow delete: if false;

      // Notas internas del Customer 360 (Fase 2, §159). Admin-gated.
      // Sin este match anidado, Firestore deniega la subcolección por defecto.
      match /crmNotes/{noteId} {
        allow read:           if hasPermission('crm.read'); // SEC-01 §187: estricto (Opción A — Gemini §169); super pasa por '*'
        allow create, update: if isSuperAdmin() || hasPermission('crm.create') || hasPermission('crm.edit');
        allow delete:         if isSuperAdmin() || hasPermission('crm.delete');
      }
    }

    // ========== ACTIVITIES (CRM canónico — timeline — Fase 1) ==========
    match /activities/{activityId} {
      allow read:           if hasPermission('crm.read'); // SEC-01 §187: estricto (Opción A — Gemini §169); super pasa por '*'
      allow create, update: if isSuperAdmin() || hasPermission('crm.edit');
      allow delete:         if isSuperAdmin() || hasPermission('crm.delete');
    }

    // ========== DEALS (CRM canónico — oportunidades/embudo — Fase 3) ==========
    // F8/F35b (ADR §181): etapas v3 + GATES + matriz de transiciones,
    // enforced en DATOS (espejo de functions/shared/crm-spec.js — el test de
    // paridad F30 lo afirma). El server (Admin SDK: trigger F2, anulación F7)
    // bypasea. Cliente obsoleto con enums v2 → denegado (pide recargar).
    match /deals/{dealId} {
      function stageIdx(s) {
        return s == 'cuadrando_cita' ? 0
          : s == 'cita_fijada' ? 1
          : s == 'visita_test_drive' ? 2
          : s == 'negociacion' ? 3
          : s == 'apartado' ? 4
          : s == 'vendido' ? 5
          : s == 'perdido' ? 6
          : -1;
      }
      function validLostReason(r) {
        return r in ['precio', 'financiacion_negada', 'compro_en_otro_lado',
                     'no_responde', 'cambio_de_opinion', 'error_de_registro', 'otro'];
      }
      // Gates de la matriz: adelante acumula (cruzar visita→huboTestDrive;
      // llegar/cruzar apartado→monto+vence; llegar a vendido→tipoPago);
      // atrás exige regressReason; vendido es terminal para el cliente.
      function dealStageChangeOk() {
        let oldS = resource.data.stageId;
        let newS = request.resource.data.stageId;
        let oi = stageIdx(oldS);
        let ni = stageIdx(newS);
        return newS == oldS
          || (
            ni >= 0 && oi >= 0
            && oldS != 'vendido'
            && (newS != 'perdido' || validLostReason(request.resource.data.lostReason))
            && (newS == 'perdido' || oldS == 'perdido' || (
                 (ni > oi && (
                    (!(oi <= 2 && ni > 2) || 'huboTestDrive' in request.resource.data)
                    && (!(oi < 4 && ni >= 4) || (request.resource.data.montoApartado is number && request.resource.data.venceEl is string))
                    // E4: ganar exige monto REAL — un won con amount 0 congela
                    // commissionSnapshot.amount=0 sin vía de corrección (F42)
                    && (ni != 5 || (request.resource.data.tipoPago in ['contado', 'financiado']
                        && request.resource.data.amount is number
                        && request.resource.data.amount > 0))
                 ))
                 || (ni < oi && request.resource.data.regressReason is string && request.resource.data.regressReason.size() > 0)
               ))
            && (oldS != 'perdido' || (request.resource.data.regressReason is string && request.resource.data.regressReason.size() > 0))
          );
      }
      // E4 §186 — campos SERVER-ONLY: wonAt + commissionSnapshot (base de
      // liquidación F42, congelada por el trigger al ganar) + retomaVehicleId
      // (callable crmCrearBorradorRetoma) + flags de idempotencia de alertas
      // del daily job (pre-setearlos atenuaría alertas F26/F28). Cliente jamás.
      function dealServerFieldsUntouched() {
        return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['wonAt', 'commissionSnapshot', 'retomaVehicleId',
                   '_colisionAlertedAt', '_apartadoVencidoAlertedAt'].toSet());
      }
      // E4 §186 — coherencia status↔stageId: sin esto un cliente podría
      // fabricar status:'won' sin pasar los gates (y entrar a comisiones F42)
      // o resucitar un vendido tocando solo status. 'anulado' = server-only.
      function dealStatusCoherent() {
        return request.resource.data.status in ['open', 'won', 'lost']
          && ((request.resource.data.status == 'won') == (request.resource.data.stageId == 'vendido'))
          && ((request.resource.data.status == 'lost') == (request.resource.data.stageId == 'perdido'));
      }
      // E4 §186 / F42 — un deal YA vendido queda CERRADO para el cliente
      // salvo el checklist post-venta F10 y campos neutros (super admin
      // conserva la válvula de corrección, menos los server-only de arriba).
      function vendidoEditOk() {
        return resource.data.stageId != 'vendido'
          || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['postventa', 'recibeVehiculo', 'lastActivityAt',
                      'updatedAt', 'updatedBy', '_version'].toSet());
      }
      allow read:   if hasPermission('crm.read'); // SEC-01 §187: estricto (Opción A — Gemini §169); super pasa por '*'
      // F7: el deal nace SOLO en cuadrando_cita, abierto, con valor y owner.
      // E4: y JAMÁS con campos server-only — un commissionSnapshot forjado en
      // el create sobreviviría al ganar (el trigger lo respeta por idempotencia).
      allow create: if (isSuperAdmin() || hasPermission('crm.edit'))
        && request.resource.data.stageId == 'cuadrando_cita'
        && request.resource.data.status == 'open'
        && request.resource.data.amount is number
        && request.resource.data.ownerId is string
        // E5 review #9: también los flags de idempotencia de alertas — un
        // create podía sembrarlos y silenciar F26/F28 (el update ya los negaba).
        && !request.resource.data.keys()
          .hasAny(['wonAt', 'commissionSnapshot', 'retomaVehicleId',
                   '_colisionAlertedAt', '_apartadoVencidoAlertedAt']);
      allow update: if (isSuperAdmin() || hasPermission('crm.edit'))
        && dealStageChangeOk()
        && dealStatusCoherent()
        && dealServerFieldsUntouched()
        && (isSuperAdmin() || vendidoEditOk());
      allow delete: if isSuperAdmin() || hasPermission('crm.delete');
    }

    // ========== SUBSCRIPTIONS (newsletter público — §164) ==========
    // El form público crea (como `solicitudes`); el trigger onSubscriptionCreated
    // ingiere al canónico. Lectura/gestión solo admin.
    match /subscriptions/{subId} {
      // SEC-06 §187 — el form escribe EXACTAMENTE 5 claves (home.js:157):
      // whitelist estricta + tipos (siempre presentes en este creador único).
      allow create: if request.resource.data.keys().hasOnly([
          'email', 'source', 'consentGiven', 'page', 'createdAt'
        ])
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 254
        // review #10: el campo EXISTE para evidenciar consentimiento (1581) —
        // un registro con false es contradictorio e inútil.
        && request.resource.data.consentGiven == true
        && (!('page' in request.resource.data)
            || (request.resource.data.page is string && request.resource.data.page.size() <= 200))
        && (!('source' in request.resource.data)
            || (request.resource.data.source is string && request.resource.data.source.size() <= 40))
        && (!('createdAt' in request.resource.data)
            || (request.resource.data.createdAt is string && request.resource.data.createdAt.size() <= 40));
      allow read:   if hasPermission('crm.read'); // SEC-01 §187: estricto (Opción A — Gemini §169); super pasa por '*'
      allow update, delete: if isSuperAdmin() || hasPermission('crm.edit');
    }

    // ========== FAILED INGESTIONS (dead-letter — Fase 1) ==========
    // Cero pérdida: si la ingestión falla, el lead cae aquí. SOLO el Admin
    // SDK escribe (bypassa rules); los admins leen para resolver.
    match /failedIngestions/{failId} {
      allow read:  if hasPermission('crm.read'); // SEC-01 §187: estricto (Opción A — Gemini §169); super pasa por '*'
      allow write: if false; // solo Admin SDK (ingestión)
    }

    // ========== CITAS (legacy — mantener para transición) ==========
    // §61.R6 — granularidad: appointments.read/edit/delete.
    match /citas/{citaId} {
      allow read: if isAuthenticated()
        || hasPermission('appointments.read');
      // E5 §187 (review #8): colección LEGACY sin NINGÚN escritor (grep js/ +
      // functions/ + portal = 0) — las citas reales viven en `solicitudes`
      // kind:'cita'. El create:if true era la regla más permisiva del archivo
      // (inyección anónima de docs falsos en las vistas admin). Cerrada.
      allow create: if false;
      allow update: if isEditorOrAbove()
        || hasPermission('appointments.edit');
      allow delete: if isSuperAdmin()
        || hasPermission('appointments.delete');
    }

    // ========== MENSAJES (MF2.5 — thread per vehicle/contact) ==========
    // §61.R6 — granularidad: concierge.read/respond/delete.
    match /mensajes/{threadId} {
      // Admin can read all threads. Owner can read their own.
      allow read: if isAuthenticated() && (
        isEditorOrAbove() ||
        hasPermission('concierge.read') ||
        (request.auth.uid == resource.data.userId)
      );
      // Anyone authenticated can create a thread (guests via anonymous auth)
      allow create: if request.auth != null && (
        !('userId' in request.resource.data)
        || request.resource.data.userId == null
        || request.resource.data.userId == request.auth.uid
      );
      // Updates: admin always; user only on their own thread
      allow update: if isAuthenticated() && (
        isEditorOrAbove() ||
        hasPermission('concierge.respond') ||
        (resource.data.userId == request.auth.uid && request.auth.uid != null)
      );
      allow delete: if isSuperAdmin()
        || hasPermission('concierge.delete');
    }

    // ========== SOLICITUDES (unified communications system) ==========
    // §61.R6 — granularidad: crm.edit/delete + appointments.edit.
    match /solicitudes/{solicitudId} {
      allow read: if isAuthenticated()
        || hasPermission('crm.read')
        || hasPermission('appointments.read');
      // MF1.1 — Anti-impersonation: if userId is set, it must match the
      // requester's auth uid (allowing anonymous). Otherwise the doc is a
      // guest submission and userId stays null. clientCategory must match.
      // SEC-06 §187 — whitelist de claves (unión LITERAL del censo de los 5
      // creadores públicos: contact/vende/financiación/cita/concierge-soft +
      // computeMeta) + caps SOLO en los campos de texto libre (condicionales:
      // el soft-lead del concierge puede traer null/ausentes). Si un form
      // legítimo agrega un campo nuevo, AÑADIRLO AQUÍ en el mismo pase.
      function solCapOk(f, max) {
        return !(f in request.resource.data)
          || request.resource.data[f] == null
          || (request.resource.data[f] is string && request.resource.data[f].size() <= max);
      }
      // E5 review #7: los maps de shape FIJO se whitelistean por subclaves y
      // los campos no-string se tipan — sin esto, cualquier clave admitía
      // 1MB de cualquier tipo.
      function solMapOk(f, allowed) {
        return !(f in request.resource.data)
          || request.resource.data[f] == null
          || (request.resource.data[f] is map
              && request.resource.data[f].keys().hasOnly(allowed));
      }
      allow create: if (
        !('userId' in request.resource.data)
        || request.resource.data.userId == null
        || (request.auth != null && request.resource.data.userId == request.auth.uid)
      )
        && request.resource.data.keys().hasOnly([
          'nombre', 'telefono', 'whatsapp', 'prefijoPais', 'email', 'tipo',
          'origen', 'kind', 'requiereCita', 'fecha', 'hora', 'vehiculo',
          'vehiculoId', 'vehiculoPrecio', 'datosExtra', 'comentarios',
          'mensaje', 'estado', 'observaciones', 'createdAt', 'userId',
          'userEmail', 'clientCategory', 'source', 'device', 'priority',
          'tags', 'slaDeadline', 'slaMs', 'sessionId', 'sourcePage',
          'sourceVehicleId', 'level', 'lastMessageAt',
          // §188 paso 0.3: el censo E5 cubrió los 5 creadores PÚBLICOS y se le
          // escapó el 6º escritor — la cita interna del clásico
          // (admin-appointments.js saveInternalAppt) firma con createdBy.
          'createdBy'
        ])
        // ⚠️ PRESUPUESTO de Rules: máx ~1000 expresiones por evaluación — los
        // caps por-campo se limitan a los vectores REALES de abuso (textos
        // largos + shapes de maps/list). Los campos enum diminutos quedan sin
        // cap individual (el hasOnly ya impide claves nuevas y la ingestión
        // normaliza); NO añadir más condiciones aquí sin medir en emulador.
        && solCapOk('nombre', 120)
        && solCapOk('email', 254)
        && solCapOk('vehiculo', 160)
        && solCapOk('mensaje', 3000)
        && solCapOk('comentarios', 3000)
        && solCapOk('observaciones', 500)
        && solCapOk('telefono', 25)
        && solCapOk('whatsapp', 25)
        && solCapOk('userEmail', 254)
        && solCapOk('sourcePage', 200)
        && solCapOk('createdBy', 254)
        && (!('tags' in request.resource.data)
            || (request.resource.data.tags is list && request.resource.data.tags.size() <= 12))
        && solMapOk('source', ['page', 'cta', 'referrer'])
        && solMapOk('device', ['type', 'browser', 'os'])
        && solMapOk('datosExtra', ['marcaVehiculo', 'modeloVehiculo', 'yearVehiculo',
            'kmVehiculo', 'precioEsperado', 'precioVehiculo', 'cuotaInicial',
            'plazo', 'ingresos', 'situacionLaboral', 'ciudad'])
        // ── §209 Vía ADMIN — captura manual del portal nuevo (createManualLead,
        //    admin-app/src/modules/capture/capture.data.js). El censo SEC-06 §187
        //    cubrió los creadores PÚBLICOS y se saltó este escritor admin (2º
        //    olvidado tras §188-0.3 createBy) → permission-denied para todos.
        //    Esta rama NO afloja la vía pública (INTACTA arriba): exige crm.edit
        //    + que el tag _createdByUid sea el PROPIO uid (anti-spoof), y solo
        //    entonces admite las 3 claves admin (consentGiven/_manual/_createdByUid)
        //    + source con campaign/traffic. ⚠️ Si añades una clave a la whitelist
        //    pública, REVÍSALA también aquí — las dos ramas evolucionan juntas.
        || (
          request.auth != null
          && hasPermission('crm.edit')
          && request.resource.data._createdByUid == request.auth.uid
          && request.resource.data.keys().hasOnly([
            'nombre', 'telefono', 'whatsapp', 'prefijoPais', 'email', 'tipo',
            'origen', 'kind', 'requiereCita', 'fecha', 'hora', 'vehiculo',
            'vehiculoId', 'vehiculoPrecio', 'datosExtra', 'comentarios',
            'mensaje', 'estado', 'observaciones', 'createdAt', 'userId',
            'userEmail', 'clientCategory', 'source', 'device', 'priority',
            'tags', 'slaDeadline', 'slaMs', 'sessionId', 'sourcePage',
            'sourceVehicleId', 'level', 'lastMessageAt', 'createdBy',
            'consentGiven', '_manual', '_createdByUid'
          ])
          && solCapOk('nombre', 120)
          && solCapOk('email', 254)
          && solCapOk('vehiculo', 160)
          && solCapOk('mensaje', 3000)
          && solCapOk('comentarios', 3000)
          && solCapOk('observaciones', 500)
          && solCapOk('telefono', 25)
          && solCapOk('whatsapp', 25)
          && solCapOk('userEmail', 254)
          && solCapOk('sourcePage', 200)
          && solCapOk('createdBy', 254)
          && (!('tags' in request.resource.data)
              || (request.resource.data.tags is list && request.resource.data.tags.size() <= 12))
          && solMapOk('source', ['page', 'cta', 'referrer', 'campaign', 'traffic'])
          && solMapOk('device', ['type', 'browser', 'os'])
          && solMapOk('datosExtra', ['marcaVehiculo', 'modeloVehiculo', 'yearVehiculo',
              'kmVehiculo', 'precioEsperado', 'precioVehiculo', 'cuotaInicial',
              'plazo', 'ingresos', 'situacionLaboral', 'ciudad'])
        );
      allow update: if isEditorOrAbove()
        || hasPermission('crm.edit')
        || hasPermission('appointments.edit');
      allow delete: if isSuperAdmin()
        || hasPermission('crm.delete');
    }

    // ========== LOGIN ATTEMPTS (cross-device account locking) ==========
    // E6 paso 0.2 (§188, cierra SEC-05/R-8): era read/create/update:true —
    // world-writable: cualquiera enumeraba cuentas o bloqueaba a un admin
    // seteando bloqueado:true (DoS del login). El lockout client-side era
    // teatro (el atacante no lo honra); la protección real es (a) la de
    // Firebase Auth (too-many-requests) y (b) el trigger onUsuarioBloqueadoSync
    // que deshabilita la cuenta Auth al bloquear. El clásico degrada en
    // silencio: TODOS sus accesos a esta colección tienen .catch (verificado
    // admin-auth.js / admin-users.js).
    match /loginAttempts/{emailHash} {
      allow read, write: if false;
    }

    // ========== AUDIT LOG ==========
    // §61.R6 — granularidad: audit.read/delete.
    match /auditLog/{logId} {
      allow read: if isAuthenticated()
        || hasPermission('audit.read');
      // Editor+ o cualquier user con permission de cualquier
      // categoría puede crear entries (la creación de un audit es
      // efecto secundario de operaciones administrativas reales).
      allow create: if isEditorOrAbove()
        || hasPermission('audit.read');
      // Super Admin can delete entries for activity management
      allow delete: if isSuperAdmin()
        || hasPermission('audit.delete');
      // F4.3: Audit log entries are IMMUTABLE — no updates allowed
    }

    // ========== AUTOMATION LOG (K.3 — workflow rule executions) ==========
    // §61.R6 — granularidad: workflows.read/edit + audit.delete.
    match /automationLog/{logId} {
      allow read: if isAuthenticated()
        || hasPermission('workflows.read')
        || hasPermission('audit.read');
      // Anyone authenticated can create — automation runs in client
      allow create: if request.auth != null;
      // Immutable: rule executions are historical facts
      allow delete: if isSuperAdmin()
        || hasPermission('audit.delete');
    }

    // ========== APPOINTMENT REMINDERS (Bloque D.5 — recordatorios mostrados) ==========
    // Tracking de qué recordatorios ya se mostraron al admin para
    // evitar dups cross-session. §61.R6 — granularidad: appointments.*
    match /appointmentReminders/{reminderId} {
      allow read: if isEditorOrAbove()
        || hasPermission('appointments.read');
      allow create: if (isEditorOrAbove()
                        || hasPermission('appointments.edit'))
                     && request.resource.data.shownTo == request.auth.uid;
      allow delete: if isSuperAdmin()
        || hasPermission('appointments.delete');
    }

    // ========== COEDITING (Bloque M.2 — co-edit locks blandos) ==========
    // Lock informativo cuando un admin abre un modal de edición.
    // Solo editor+ pueden leer/escribir. Solo el dueño del lock o
    // super_admin lo elimina.
    match /coediting/{lockId} {
      allow read: if isEditorOrAbove();
      allow create: if isEditorOrAbove() &&
                     request.resource.data.editorUid == request.auth.uid;
      allow update: if isEditorOrAbove() &&
                     resource.data.editorUid == request.auth.uid;
      allow delete: if isSuperAdmin() ||
                     (isEditorOrAbove() && resource.data.editorUid == request.auth.uid);
    }

    // ========== COMMENTS (Bloque M.4 — comentarios threaded entre admins) ==========
    // Sistema universal de comentarios sobre cualquier entidad. Solo
    // editor+ pueden leer/comentar. Author del comentario o super_admin
    // pueden eliminarlo.
    match /comments/{commentId} {
      allow read: if isEditorOrAbove();
      allow create: if isEditorOrAbove() &&
                     request.resource.data.authorUid == request.auth.uid;
      allow update: if isEditorOrAbove() &&
                     resource.data.authorUid == request.auth.uid &&
                     request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['body', 'edited', 'updatedAt']);
      allow delete: if isSuperAdmin() ||
                     (isEditorOrAbove() && resource.data.authorUid == request.auth.uid);
    }

    // ========== KNOWLEDGE BASE (Bloque U.5 — FAQs del bot Concierge) ==========
    // Admin (editor+) gestiona via UI. Cliente público lee para que el bot
    // del Concierge consulte respuestas.
    // §61.R6 — granularidad: kb.create/edit/delete.
    match /knowledgeBase/{kbId} {
      allow read: if true; // público lee para el bot
      allow create: if isEditorOrAbove()
        || hasPermission('kb.create');
      // Editor+ (o roles con kb.edit) modifican todo. Cualquier user
      // autenticado puede tocar SOLO usageCount + lastUsedAt (analytics
      // que el bot reporta — no requiere kb.edit explícito).
      allow update: if isEditorOrAbove()
        || hasPermission('kb.edit')
        || (request.auth != null
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['usageCount', 'lastUsedAt']));
      allow delete: if isSuperAdmin()
        || hasPermission('kb.delete');
    }

    // FASE 3 — Rate limit per session para el LLM (chatLLM Cloud Function).
    // La Cloud Function escribe via Admin SDK (bypasea rules). Desde cliente
    // bloqueamos lectura/escritura para evitar manipulación del contador.
    match /llmRateLimit/{sessionId} {
      allow read, write: if false;
    }

    // ========== OFFLINE ULTRA BRAIN — Capa E: Auto-Nutrición / Feedback Loop ==========
    // Cuando el bot rule-based cae al fallback genérico (no entiende la
    // pregunta), `concierge.js logUnmatched()` escribe la query a esta
    // colección. El admin la revisa en la sección Cerebro AI → tab "Lo que
    // no entendí" y la promueve a FAQ con un click.
    //
    // - create: cualquier sesión autenticada (incluye guests anónimos)
    // - read/update: editor+ (revisar + marcar como vista/promovida)
    // - delete: super_admin
    // §61.R6 — granularidad: unmatched.read/promote/delete.
    match /unmatchedQueries/{queryId} {
      allow read: if isEditorOrAbove()
        || hasPermission('unmatched.read');
      allow update: if isEditorOrAbove()
        || hasPermission('unmatched.promote');
      allow create: if request.auth != null;
      allow delete: if isSuperAdmin()
        || hasPermission('unmatched.delete');
    }

    // ========== EVENT BUS (I.1 / I.2 — admin Activity Feed) ==========
    // §61.R6 — granularidad: audit.read/delete.
    match /events/{eventId} {
      // Authenticated users can read (Activity Feed shows them)
      allow read: if isAuthenticated()
        || hasPermission('audit.read');
      // Anyone authenticated can create — events are produced by both
      // admin and registered clients. The bySource field tracks origin.
      allow create: if request.auth != null;
      // Immutable like auditLog — no updates allowed
      allow delete: if isSuperAdmin()
        || hasPermission('audit.delete');
    }

    // ========== CONCIERGE CHATS (Bloque U — chat unificado bot/live) ==========
    // Cada cliente tiene su propia conversación identificada por sessionId.
    // El cliente puede leer/escribir su propio chat. Los admins (editor+) leen
    // y responden todos. La regla de anti-impersonation requiere que el
    // userId del doc matchee el auth.uid si está seteado.
    match /conciergeChats/{sessionId} {
      // §61.R6 — granularidad: concierge.read.
      allow read: if isEditorOrAbove()
        || hasPermission('concierge.read')
        || (request.auth != null && (
          resource.data.userId == request.auth.uid ||
          resource.data.userId == null
        ));
      allow create: if request.auth != null && (
        !('userId' in request.resource.data) ||
        request.resource.data.userId == null ||
        request.resource.data.userId == request.auth.uid
      );
      // §23 FASE 3 — Locks (Claiming).
      // Update permitido si:
      //   1. Es super_admin (override total: liberación de lock, reasignación)
      //   2. El claim no existe (claimedBy == null) → admin con concierge.claim/edit puede tomar
      //   3. El que actualiza ES el claimer original (claimedBy == auth.uid)
      //   4. El cliente dueño actualiza su propio chat (campos limitados via diff
      //      keys — pero permisivo aquí, la subcolección messages ya tiene su
      //      propio guard de status='closed')
      //
      // §61.R6 — granularidad: concierge.claim/edit/transfer/close.
      allow update: if isSuperAdmin()
        || (isEditorOrAbove() && (
            resource.data.claimedBy == null
            || resource.data.claimedBy == request.auth.uid
        ))
        || ((hasPermission('concierge.claim')
             || hasPermission('concierge.transfer')
             || hasPermission('concierge.close')
             || hasPermission('concierge.reopen')) && (
            resource.data.claimedBy == null
            || resource.data.claimedBy == request.auth.uid
        ))
        || (request.auth != null && (
            resource.data.userId == request.auth.uid
            || resource.data.userId == null
        ));
      allow delete: if isSuperAdmin()
        || hasPermission('concierge.delete');

      // Subcolección de mensajes — cada turno del bot/asesor/cliente
      match /messages/{msgId} {
        // §61.R6 — granularidad: concierge.read.
        allow read: if isEditorOrAbove() ||
          hasPermission('concierge.read') ||
          (request.auth != null && (
            get(/databases/$(database)/documents/conciergeChats/$(sessionId)).data.userId == request.auth.uid ||
            get(/databases/$(database)/documents/conciergeChats/$(sessionId)).data.userId == null
          ));
        // §23 FASE 5 — Cierre bidireccional INMUTABLE.
        // Si el parent.status == 'closed', NADIE puede crear messages
        // excepto super_admin (override de auditoría / reapertura).
        // Esto garantiza que un chat cerrado quede como registro
        // histórico inmutable tanto para el cliente como para el asesor.
        //
        // Roles permitidos por tipo de from:
        //   from: 'user' o 'bot' → cualquiera autenticado
        //   from: 'asesor'       → solo isEditorOrAbove
        //   from: 'system'       → solo isEditorOrAbove (closeChat/reopenChat,
        //                          handoff a asesor, etc. — anti-impersonation)
        allow create: if request.auth != null
          && (
            // BLOQUEO BIDIRECCIONAL: chat cerrado solo super_admin
            // puede agregar mensajes (override / reapertura)
            get(/databases/$(database)/documents/conciergeChats/$(sessionId)).data.status != 'closed'
            || isSuperAdmin()
          )
          && (
            request.resource.data.from in ['user', 'bot']
            // §23 FASE 3 — Solo el CLAIMER (o super_admin override) puede
            // escribir mensajes 'asesor'. §61.R6 agrega path con permission
            // 'concierge.respond'.
            //
            // Lógica:
            //   a) Si el chat NO tiene claim (claimedBy null) → cualquier
            //      editor+ o user con concierge.respond puede escribir
            //   b) Si tiene claim → solo claimedBy == auth.uid
            //   c) super_admin siempre puede (override de auditoría)
            || (request.resource.data.from == 'asesor' && (
                isSuperAdmin()
                || ((isEditorOrAbove() || hasPermission('concierge.respond')) && (
                    !('claimedBy' in get(/databases/$(database)/documents/conciergeChats/$(sessionId)).data)
                    || get(/databases/$(database)/documents/conciergeChats/$(sessionId)).data.claimedBy == null
                    || get(/databases/$(database)/documents/conciergeChats/$(sessionId)).data.claimedBy == request.auth.uid
                ))
            ))
            // Mensajes 'system' (closeChat/reopenChat/asesor_joined/etc):
            // editor+ o user con concierge.respond/close/reopen.
            || (request.resource.data.from == 'system' && (
                isEditorOrAbove()
                || hasPermission('concierge.respond')
                || hasPermission('concierge.close')
                || hasPermission('concierge.reopen')
            ))
          );
        // Mensajes son inmutables (historial limpio)
        allow delete: if isSuperAdmin()
          || hasPermission('concierge.delete');
      }

      // §88 Sprint C-S10 — Subcolección notes/: notas privadas del
      // asesor. Defense-in-depth: el cliente NO matchea ninguna rule
      // de esta subcolección → cero ruleo posible (ni lectura ni
      // escritura), independientemente del rol legacy o permissions[].
      //
      // Solo isEditorOrAbove (admins) puede leer/escribir/borrar.
      // Los notes nunca aparecen en el flujo del cliente — ni en el
      // listener de messages ni en ninguna parte del concierge.js.
      // Aislamiento absoluto del cliente.
      match /notes/{noteId} {
        allow read: if isEditorOrAbove()
          || hasPermission('concierge.read');
        allow create: if isEditorOrAbove()
          || hasPermission('concierge.respond');
        // Notas son inmutables tras crear (audit trail limpio).
        // Solo super_admin puede borrar (auditoría).
        allow update: if false;
        allow delete: if isSuperAdmin();
      }
    }

    // ========== CONFIG ==========
    // §61.R6 — granularidad: settings.theme/seo/backup + calendar.config.
    match /config/{docId} {
      allow read: if true;
      // counters: editor+ can update
      // calendarConfig: requires calendar.config (settings de slots/turnos)
      // followups, messageTemplates: requires templates.edit
      // everything else: super_admin / settings.* permissions
      function configAdminWrite() {
        return isSuperAdmin()
          || (isEditorOrAbove() && docId in ['counters', 'bookedSlots'])
          // E5 review #5: reprogramar entre fechas toca 2 claves (release+
          // reserve) — el staff de citas permissions-only no es "editor".
          || (docId == 'bookedSlots' && hasPermission('appointments.edit'))
          || (docId == 'counters' && hasPermission('settings.backup'))
          || (docId == 'calendarConfig' && hasPermission('calendar.config'))
          // F21 §184: availability = SSoT de disponibilidad (mismo permiso).
          || (docId == 'availability' && hasPermission('calendar.config'))
          || (docId == 'followups' && hasPermission('templates.edit'))
          || (docId == 'messageTemplates' && hasPermission('templates.edit'))
          || hasPermission('settings.theme')
          || hasPermission('settings.seo')
          || hasPermission('settings.backup');
      }
      // SEC-08 §187 — la reserva atómica del form público (citas.js:515) sigue
      // viva pero ACOTADA: antes `(docId == 'bookedSlots')` a secas permitía
      // create/update/DELETE sin auth (cualquiera borraba el doc de cupos).
      // Ahora: auth (anónima del sitio cuenta), jamás delete, y el diff toca
      // UNA sola clave por request (la tx del form reserva una fecha a la vez;
      // el doc lo siembra/reconstruye el server — crmDailyJob rebuild F17c).
      // Riesgo RESIDUAL documentado (review #6): la rama pública no puede
      // validar el NOMBRE/VALOR de la clave (rules no extraen claves de un
      // diff) — un anónimo-auth puede corromper UNA fecha por request. Capas
      // que lo acotan: bound de claves totales (abajo), rebuild nocturno F17c
      // auto-repara, la tupla server-side (resource_slots E2) protege el
      // recurso real, y App Check enforce (gate ~16/06) cierra el abuso por
      // script. Cerrarlo del todo = mover la reserva a callable (rompe el
      // puente — prohibido).
      allow create: if configAdminWrite()
        || (docId == 'bookedSlots' && request.auth != null
            && request.resource.data.keys().size() == 1);
      allow update: if configAdminWrite()
        || (docId == 'bookedSlots' && request.auth != null
            && request.resource.data.diff(resource.data).affectedKeys().size() == 1
            && request.resource.data.keys().size() <= 400);
      allow delete: if isSuperAdmin();
    }

    // ========== DEDUP / MERGES / SUPPRESSIONS (E3 §185 — solo server) ==========
    // dedup/{key}: índice email/tel→contactId (F40e). El portal lo LEE para
    // detectar colisiones al editar; SOLO el Admin SDK escribe.
    match /dedup/{key} {
      allow read: if isEditorOrAbove() || hasPermission('crm.read')
        || hasPermission('crm.edit');
      allow write: if false;
    }
    // Estado de fusiones (resumible B.5) y supresiones (gracia 72h F14).
    match /merges/{mergeId} {
      allow read: if isEditorOrAbove() || hasPermission('crm.read');
      allow write: if false;
    }
    match /suppressions/{contactId} {
      allow read: if isEditorOrAbove() || hasPermission('crm.read')
        || hasPermission('crm.delete');
      allow write: if false;
    }

    // ========== CRM CONFIG PRIVADA (§184) ==========
    // advisorOverrides (ausencias con nombre+motivo = PII/dato sensible) vive
    // AQUÍ y no en config/* porque config tiene read público (el form web).
    match /crm_config/{docId} {
      allow read: if isEditorOrAbove() || hasPermission('crm.read')
        || hasPermission('crm.edit') || hasPermission('calendar.config');
      allow write: if isSuperAdmin() || hasPermission('calendar.config');
    }

    // ========== RESOURCE SLOTS (F19 §184 — tupla asesor+vehículo) ==========
    // Bloques de 30min por día: { 'asesor_<uid>': ['10:00'], 'vehiculo_<id>': [...] }.
    // SOLO escribe el Admin SDK (callable crmCitaAction + jobs). El staff lee
    // para pintar disponibilidad al confirmar/reprogramar.
    match /resource_slots/{day} {
      allow read: if isEditorOrAbove() || hasPermission('crm.read')
        || hasPermission('crm.edit') || hasPermission('calendar.config');
      allow write: if false;
    }

    // ========== DRAFTS ACTIVOS (admin collaboration) ==========
    // §61.R6 — granularidad: vehicles.edit (drafts son co-edit de inventario).
    match /drafts_activos/{userId} {
      allow read: if isEditorOrAbove()
        || hasPermission('vehicles.edit');
      allow write: if (isEditorOrAbove() || hasPermission('vehicles.edit'))
        && request.auth.uid == userId;
      allow delete: if isEditorOrAbove()
        || hasPermission('vehicles.edit');
    }

    // ========== SYSTEM (cache invalidation) ==========
    // §61.R6 — cache invalidation requiere settings.theme/seo/backup
    // (cualquier admin que modifique algo dispara invalidación).
    match /system/{docId} {
      allow read: if true;
      // E5 §187 (review #11): el bootstrap (!exists) exigía CERO auth →
      // cualquiera sin autenticar squatteaba docs system/* world-readable.
      // Con auth (la anónima del sitio cuenta) el bootstrap legítimo sigue.
      allow write: if isEditorOrAbove()
        || hasPermission('settings.theme')
        || hasPermission('settings.seo')
        || hasPermission('settings.backup')
        || (request.auth != null
            && !exists(/databases/$(database)/documents/system/$(docId)));
    }

    // ========== §61.R1 RBAC — PERMISSIONS CATALOG (read-only) ==========
    // Catálogo canónico de permissions atómicas. Sembrado por Cloud
    // Function seedSystemRoles. §61.R6 — granularidad: roles.read.
    match /permissions/{permId} {
      allow read: if isEditorOrAbove()
        || hasPermission('roles.read');
      allow write: if false; // Server-only via Cloud Function
    }

    // ========== §61.R1 RBAC — ROLES (system + custom) ==========
    // §61.R6 — granularidad: roles.read/create/edit/delete.
    match /roles/{roleId} {
      allow read: if isEditorOrAbove()
        || hasPermission('roles.read');
      allow create: if isSuperAdmin()
        || hasPermission('roles.create');
      // §212: los system roles (CEO 'system_super_admin' con '*') son INMUTABLES desde
      // el cliente — solo el CF seedSystemRoles (Admin SDK) los toca. Antes cualquier
      // roles.edit/roles.delete podía editar/borrar el rol del dueño (hueco FATAL; el
      // comentario de onRoleDeleted asumía este bloqueo que NO existía).
      allow update: if (isSuperAdmin() || hasPermission('roles.edit'))
        && resource.data.get('isSystem', false) == false;
      allow delete: if (isSuperAdmin() || hasPermission('roles.delete'))
        && resource.data.get('isSystem', false) == false;
    }

    // ========== DEPARTMENTS (§215 ④a — catálogo departamental) ==========
    // Espejo de roles/. El CEO ('*' o super_admin legacy) siempre pasa; el resto
    // por permiso departments.read/manage. Los helpers de nivel/depto/scope para
    // el SCOPING de datos llegan en ④b (no aquí — ④a solo establece la colección).
    match /departments/{deptId} {
      allow read: if isSuperAdmin()
        || hasPermission('departments.read')
        || hasPermission('departments.manage');
      allow create: if isSuperAdmin() || hasPermission('departments.manage');
      allow update: if isSuperAdmin() || hasPermission('departments.manage');
      // §66 — no borrar un departamento con usuarios asignados (userCount>0).
      allow delete: if (isSuperAdmin() || hasPermission('departments.manage'))
        && resource.data.get('userCount', 0) == 0;
    }

    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
