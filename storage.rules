rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: get user role from Firestore
    function isAuthenticated() {
      return request.auth != null;
    }

    // CMS FASE 0.2 (Decisión Fuerte comité v4 + 2ª opinión Gemini, ambos "WRONG" al `image/.*`):
    // contentType pasa de `image/.*` a `image/(png|jpeg|webp)` → RECHAZA `image/svg+xml`
    // (un SVG puede ejecutar JS; GitHub Pages single-origin → tocaría la sesión admin + siteContent).
    // 1ª capa server-side, cubre AMBOS uploaders (flat admin-brands.js + modular brands.ui.js) de un golpe.
    // ⚠️ `contentType` es DECLARADO-por-cliente (falsificable: bytes SVG con header png pasan) → es 1ª capa,
    //    NO suficiente sola. Capa 2 (la que cierra el bypass, gratis): servir logos SIEMPRE como <img src>,
    //    nunca inline/navegable (un SVG en <img> no ejecuta JS). 0.2b pendiente: purga retroactiva de los
    //    svg ya en Storage (rechazar futuros no borra los existentes). Cap de tamaño: sin cambio (inventario antes).

    // ========== VEHICLE & BRAND IMAGES ==========
    // cars/ — vehicle images and brand logos
    match /cars/{allPaths=**} {
      // Anyone can read (public catalog images)
      allow read: if true;
      // Authenticated users can upload (max 5MB, images only)
      allow write: if isAuthenticated()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    // brands/ — brand logo uploads
    match /brands/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    // banners/ — promotional banner uploads
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if isAuthenticated()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    // avatars/ — user profile photos (max 500KB, images only)
    // Filename is always {uid}.webp — uid ownership enforced client-side
    match /avatars/{fileName} {
      allow read: if true;
      allow write: if isAuthenticated()
        && request.resource.size < 512 * 1024
        && request.resource.contentType.matches('image/(png|jpeg|webp)');
    }

    // Default: deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
